{
  "info": {
    "name": "AP2 Assignment 1 - Order & Payment",
    "_postman_id": "9d88c32a-0000-0000-0000-000000000000",
    "description": "Postman collection for Order/Payment microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Order health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-001\",\n  \"item_name\": \"Laptop\",\n  \"amount\": 50000\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "orders"]
            }
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/orders/{{order_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Cancel order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/orders/{{order_id}}/cancel",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "orders", "{{order_id}}", "cancel"]
            }
          }
        },
        {
          "name": "Create order with Idempotency-Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotency_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-001\",\n  \"item_name\": \"Phone\",\n  \"amount\": 30000\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Payment health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Create payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"{{order_id}}\",\n  \"amount\": 15000\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/v1/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "payments"]
            }
          }
        },
        {
          "name": "Get payment by order id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/api/v1/payments/{{order_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "payments", "{{order_id}}"]
            }
          }
        }
      ]
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "order_id",
      "value": ""
    },
    {
      "key": "idempotency_key",
      "value": "my-unique-key-abc123"
    }
  ]
}